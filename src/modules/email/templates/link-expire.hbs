<html>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>The link has expired</title>
    <style>
      body {
        font-family: 'Trebuchet MS', 'Segoe UI', Arial, sans-serif;
      }
    </style>
  </head>
  <body
    style="margin: 0; padding: 24px 16px; background-color: #f4f5f6; font-family: 'Trebuchet MS', 'Segoe UI', Arial, sans-serif;"
  >
    <table
      border='0'
      cellpadding='0'
      cellspacing='0'
      width='100%'
      style='max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);'
    >
      <tr>
        <td style='padding: 30px 40px; text-align: left;'>
          <table border='0' cellpadding='0' cellspacing='0'>
            <tr>
              <td style='padding-right: 8px;'>
                <img
                  src='https://res.cloudinary.com/ds6nd4lbj/image/upload/v1778427951/logo_ej4zdv.svg'
                  alt='EnergyIQ'
                  height='32'
                />
              </td>
              <td
                style='font-size: 16px; font-weight: 700; color: #111827; letter-spacing: 0.5px;'
              >
                ENERGY<span style='color: #F5A623;'>IQ</span>
              </td>
            </tr>
          </table>
        </td>
      </tr>
      <tr>
        <td style='padding: 12px 40px 8px; text-align: center;'>
          <img
            src='https://img.icons8.com/ios-filled/64/9CA3AF/secured-letter.png'
            alt='Link expired'
            width='64'
            style='display: block; margin: 0 auto; border: 0;'
          />
        </td>
      </tr>

      <tr>
        <td style='padding: 8px 40px 20px;'>
          <h1
            style='font-size: 28px; font-weight: bold; color: #F5A623; margin: 0 0 20px 0; text-align: center;'
          >The link has expired</h1>

          <p
            style='font-size: 18px; font-weight: bold; color: #111827; margin: 0 0 10px 0;'
          >Hi {{firstName}},</p>
          <p
            style='font-size: 16px; color: #4b5563; line-height: 1.5; margin: 0 0 30px 0;'
          >
            Your password reset has expired or has already been used.
          </p>

          <a
            href='{{requestUrl}}'
            style='background-color: #F5A623; color: #111928; padding: 16px 40px; text-decoration: none; border-radius: 8px; font-weight: bold; display: block; margin-bottom: 30px; text-align: center; font-size: 16px;'
          >Request New Link</a>

          <p
            style='font-size: 14px; color: #6b7280; line-height: 1.5; margin: 0 0 5px 0;'
          >
            For security reasons, password reset links expire after 10 minutes
            and can only be used once.
          </p>
          <p
            style='font-size: 14px; font-weight: bold; color: #111827; margin: 0 0 5px 0;'
          >Didn't create an account?</p>
          <p
            style='font-size: 14px; color: #6b7280; line-height: 1.5; margin: 0 0 30px 0;'
          >
            If you didn't request a password reset, you can safely ignore this
            email.
          </p>

          <p style='font-size: 14px; color: #111827; margin: 0;'>Regards,</p>
          <p
            style='font-size: 14px; color: #111827; font-weight: bold; margin: 5px 0 0 0;'
          >The EnergyIQ Team</p>
        </td>
      </tr>
      <tr>
        <td
          style='padding: 40px; background-color: #D8DBE2; text-align: center;'
        >
          <div style='margin-bottom: 12px;'>
            <img
              src='https://res.cloudinary.com/ds6nd4lbj/image/upload/v1778441114/facebook_llfkvr.svg'
              alt='Facebook'
              width='24'
              height='24'
              style='margin: 0 4px;'
            />
            <img
              src='https://res.cloudinary.com/ds6nd4lbj/image/upload/v1778441114/in_p7abpg.svg'
              alt='LinkedIn'
              width='24'
              height='24'
              style='margin: 0 4px;'
            />
            <img
              src='https://res.cloudinary.com/ds6nd4lbj/image/upload/v1778441115/x_wlwnww.svg'
              alt='X'
              width='24'
              height='24'
              style='margin: 0 4px;'
            />
            <img
              src='https://res.cloudinary.com/ds6nd4lbj/image/upload/v1778441114/discord_fcivey.svg'
              alt='Discord'
              width='24'
              height='24'
              style='margin: 0 4px;'
            />
            <img
              src='https://res.cloudinary.com/ds6nd4lbj/image/upload/v1778443756/mail-small_le1rgp.svg'
              alt='Mail'
              width='24'
              height='24'
              style='margin: 0 4px;'
            />
          </div>
          <p style='font-size: 12px; color: #6b7280; margin: 0;'>© 2025
            EnergyIQ. All rights reserved.</p>
          <p style='font-size: 12px; color: #9ca3af; margin: 5px 0 0 0;'>This is
            an automated email, please do not reply.</p>
        </td>
      </tr>
    </table>
  </body>
</html>