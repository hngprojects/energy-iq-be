NODE_ENV=development
PORT=3330
HOST=localhost
CLIENT_URL=http://localhost:3000
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,https://app.energyiq.com # dummy

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=energy_iq_user
DATABASE_PASSWORD=change-me-to-a-secure-password
DATABASE_NAME=energy_iq_db
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DEFAULT_TTL=900

RESEND_API_KEY=api_key
RESEND_FROM=energyiq@hng14.com
SUPPORT_EMAIL=energyiq@hng14.com
# Google Auth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=your_callback_url

# JWT (must be at least 32 characters each)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Misc
CORS_ORIGIN=*
SWAGGER_ENABLED=true
